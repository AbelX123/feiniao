# 复制此文件为 .env，并填写实际值
# cp .env.example .env

# ==============================
# MySQL（必填）
# ==============================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=feiniao
MYSQL_USERNAME=feiniao
MYSQL_PASSWORD=your_mysql_password

# ==============================
# Redis（必填）
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password

# ==============================
# MinIO 对象存储（feiniao-users 必填）
# ==============================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ==============================
# DeepSeek API（feiniao-recommendation 必填）
# 申请地址：https://platform.deepseek.com/
# ==============================
DEEPSEEK_API_KEY=sk-your_deepseek_api_key

# ==============================
# 阿里云短信（feiniao-users 手机号登录必填）
# 可设 ALIYUN_SMS_FALLBACK_ENABLED=true 跳过真实短信发送（本地调试用）
# ==============================
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxxx
ALIYUN_SMS_FALLBACK_ENABLED=false

# ==============================
# 支付宝支付（feiniao-payments 必填）
# 申请地址：https://open.alipay.com/
# ==============================
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_MERCHANT_PRIVATE_KEY=your_merchant_rsa_private_key
ALIPAY_PUBLIC_KEY=your_alipay_rsa_public_key
ALIPAY_RETURN_URL=http://localhost:5173/orders
ALIPAY_NOTIFY_URL=http://your-domain/api/alipay/notify

# ==============================
# 服务间调用地址
# Docker Compose 部署时使用服务名，本地开发使用 localhost
# ==============================
MCP_SERVER_URL=http://localhost:8084
FEINIAO_USERS_BASE_URL=http://localhost:8080
FEINIAO_DICTS_BASE_URL=http://localhost:8081

# ==============================
# 各服务端口（可选，默认 8080-8085）
# ==============================
# SERVER_PORT_USERS=8080
# SERVER_PORT_DICTS=8081
# SERVER_PORT_ORDERS=8082
# SERVER_PORT_RECOMMENDATION=8083
# SERVER_PORT_MCP=8084
# SERVER_PORT_PAYMENTS=8085
